{
  "name": "liveline-vue",
  "version": "0.0.7",
  "type": "module",
  "description": "Real-time animated charts for Vue 3 \u2014 line, candlestick, and multi-series modes",
  "keywords": [
    "vue",
    "vue3",
    "chart",
    "canvas",
    "real-time",
    "animation",
    "line-chart",
    "candlestick",
    "ohlc",
    "multi-series"
  ],
  "license": "MIT",
  "author": "Benji Taylor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benjitaylor/liveline.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/benjitaylor/liveline#readme",
  "bugs": "https://github.com/benjitaylor/liveline/issues",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "liveline-core": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  }
}
