{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vue", "node"],
    "paths": {
      "liveline-vue": ["../../packages/vue/src/index.ts"],
      "liveline-core": ["../../packages/core/src/index.ts"]
    }
  },
  "include": ["App.vue", "main.ts", "useDemoData.ts", "vite.config.ts"]
}
