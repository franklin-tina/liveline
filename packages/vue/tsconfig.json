{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vue"],
    "paths": { "liveline-core": ["../core/src/index.ts"] }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
